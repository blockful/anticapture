{
  "name": "@anticapture/client-docs",
  "version": "0.0.1",
  "private": true,
  "description": "Documentation site for the Anticapture MCP server (@anticapture/client).",
  "scripts": {
    "docusaurus": "docusaurus",
    "prepare-spec": "tsx scripts/prepare-spec.mjs",
    "wait-for-gateful": "tsx scripts/wait-for-gateful.mjs",
    "start": "pnpm prepare-spec && docusaurus gen-api-docs all && docusaurus start --port 3001",
    "build": "pnpm prepare-spec && docusaurus gen-api-docs all && docusaurus build",
    "serve": "docusaurus serve --port 3001",
    "gen-api": "pnpm prepare-spec && docusaurus gen-api-docs all",
    "clean-api": "docusaurus clean-api-docs all",
    "clear": "docusaurus clear",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@easyops-cn/docusaurus-search-local": "0.55.2",
    "@signalwire/docusaurus-plugin-llms-txt": "1.2.2",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.1.0",
    "docusaurus-plugin-openapi-docs": "5.0.2",
    "docusaurus-theme-openapi-docs": "5.0.2",
    "prism-react-renderer": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "tsx": "^4.21.0",
    "typescript": "~5.6.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
