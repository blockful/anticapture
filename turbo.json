{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "db:prune": { "cache": false },
    "@anticapture/observability#build": {
      "outputs": ["packages/observability/dist/**"]
    },
    "@anticapture/dashboard#start": {
      "persistent": true,
      "cache": false,
      "env": ["RESEND_API_KEY", "RESEND_FROM_EMAIL", "CONTACT_EMAIL"]
    },
    "@anticapture/dashboard#dev": {
      "dependsOn": ["@anticapture/graphql-client#codegen"],
      "persistent": true,
      "cache": false
    },
    "@anticapture/graphql-client#dev": {
      "persistent": true
    },
    "@anticapture/dashboard#build": {
      "dependsOn": ["@anticapture/graphql-client#codegen"],
      "outputs": ["dist/**", ".next/**", ".next/cache/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", ".next/cache/**"],
      "env": ["RESEND_API_KEY", "RESEND_FROM_EMAIL", "CONTACT_EMAIL"]
    },
    "storybook": {
      "outputs": ["dist/**", ".next/**", ".next/cache/**"]
    },
    "build-storybook": {
      "outputs": ["storybook-static/**"]
    },
    "start": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false,
      "passThroughEnv": ["*"]
    },
    "clean": {},
    "lint": {
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.js",
        "**/*.jsx",
        "eslint.config.*"
      ]
    },
    "lint:fix": {
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.js",
        "**/*.jsx",
        "eslint.config.*"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["**/*.ts", "**/*.tsx", "tsconfig.json", "tsconfig.*.json"]
    },
    "test": {
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.test.*"]
    },
    "test:unit": {
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.test.*"]
    },
    "codegen": {
      "inputs": ["packages/graphql-client/documents/**/*"],
      "outputs": ["packages/graphql-client/generated/**"]
    },
    "db:generate": {
      "inputs": ["src/**/*.ts"],
      "outputs": ["drizzle/**"]
    },
    "@anticapture/api#dev": {
      "dependsOn": ["@anticapture/observability#build"],
      "passThroughEnv": ["*"]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "passThroughEnv": ["*"]
    },
    "dev:rw": {
      "persistent": true,
      "cache": false,
      "passThroughEnv": ["*"]
    }
  }
}
