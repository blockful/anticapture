{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "@anticapture/indexer#db:*": {
      "cache": false,
      "passThroughEnv": ["*"]
    },
    "@anticapture/graphql-client#codegen": {
      "inputs": [
        "documents/**/*",
        "codegen.ts",
        "$TURBO_ROOT$/apps/api-gateway/schema.graphql"
      ],
      "outputs": ["generated/**"]
    },
    "@anticapture/client#codegen": {
      "inputs": [
        "kubb.config.ts",
        "src/**",
        "$TURBO_ROOT$/apps/gateful/openapi/gateful.json"
      ],
      "outputs": ["generated/**"]
    },
    "@anticapture/graphql-client#build": {
      "dependsOn": ["codegen", "^build"],
      "outputs": ["dist/**"]
    },
    "@anticapture/client#build": {
      "dependsOn": ["codegen"],
      "outputs": ["dist/**"]
    },
    "@anticapture/dashboard#build": {
      "dependsOn": ["^codegen", "^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "storybook": {
      "persistent": true,
      "cache": false
    },
    "@anticapture/dashboard#build-storybook": {
      "dependsOn": ["^codegen", "^build"],
      "outputs": ["storybook-static/**"]
    },
    "build-storybook": {
      "outputs": ["storybook-static/**"]
    },
    "start": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false,
      "passThroughEnv": ["*"]
    },
    "clean": {
      "cache": false
    },
    "//#changeset": {
      "cache": false,
      "interactive": true
    },
    "lint": {
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.js",
        "**/*.jsx",
        "eslint.config.*"
      ]
    },
    "lint:fix": {
      "cache": false,
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.js",
        "**/*.jsx",
        "eslint.config.*"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["**/*.ts", "**/*.tsx", "tsconfig.json", "tsconfig.*.json"]
    },
    "@anticapture/client#typecheck": {
      "dependsOn": ["@anticapture/client#codegen", "^build"],
      "inputs": ["**/*.ts", "**/*.tsx", "tsconfig.json", "tsconfig.*.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.test.*"]
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.test.*"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "passThroughEnv": [
        "CI",
        "PLAYWRIGHT_BASE_URL",
        "NEXT_PUBLIC_BASE_URL",
        "NEXT_PUBLIC_GATEFUL_URL",
        "NEXT_PUBLIC_WC_PROJECT_ID"
      ]
    },
    "@anticapture/dashboard#test:e2e:headed": {
      "cache": false,
      "passThroughEnv": [
        "CI",
        "PLAYWRIGHT_BASE_URL",
        "NEXT_PUBLIC_BASE_URL",
        "NEXT_PUBLIC_GATEFUL_URL",
        "NEXT_PUBLIC_WC_PROJECT_ID"
      ]
    },
    "@anticapture/dashboard#test:e2e:ui": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "CI",
        "PLAYWRIGHT_BASE_URL",
        "NEXT_PUBLIC_BASE_URL",
        "NEXT_PUBLIC_GATEFUL_URL",
        "NEXT_PUBLIC_WC_PROJECT_ID"
      ]
    },
    "codegen": {
      "outputs": ["generated/**"]
    },
    "db:generate": {
      "inputs": ["src/**/*.ts"],
      "outputs": ["drizzle/**"]
    },
    "@anticapture/indexer": {
      "env": ["DAO_ID"]
    },
    "@anticapture/api": {
      "env": [
        "DAO_ID",
        "CHAIN_ID",
        "TREASURY_DATA_PROVIDER_API_URL",
        "TREASURY_DATA_PROVIDER_ID"
      ]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false,
      "passThroughEnv": ["*"]
    },
    "@anticapture/client#mcp": {
      "dependsOn": ["@anticapture/client#codegen"],
      "persistent": true,
      "cache": false,
      "passThroughEnv": ["*"]
    },
    "@anticapture/client#mcp-http": {
      "dependsOn": ["@anticapture/client#codegen"],
      "persistent": true,
      "cache": false,
      "passThroughEnv": ["*"]
    },
    "@anticapture/relayer#dev:fork": {
      "persistent": true,
      "cache": false,
      "passThroughEnv": ["*"]
    }
  }
}
