{
  "name": "@anticapture/api",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:watch": "vitest",
    "clean": "rm -rf node_modules *.tsbuildinfo dist",
    "start": "node --import ./dist/instrumentation.js dist/index.js",
    "start:aave": "node --import ./dist/instrumentation.js dist/aave.js",
    "build": "tsup",
    "build:watch": "tsc --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "dev": "tsx watch cmd/index.ts",
    "dev:rw": "sh -c 'dao_id=\"$1\"; exec railway run -e dev -s \"${dao_id}-api\" -- pnpm dev' --",
    "db:migrate": "drizzle-kit migrate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@anticapture/observability": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^1.2.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "axios": "^1.9.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.10",
    "pg": "^8.17.2",
    "pino-http": "^10.4.0",
    "viem": "^2.41.2",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "drizzle-seed": "^0.3.1",
    "@electric-sql/pglite": "^0.3.15",
    "@types/node": "^20.16.5",
    "@types/pg": "^8.15.6",
    "@vitest/coverage-v8": "3.2.4",
    "dotenv": "^16.5.0",
    "eslint": "^9",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "msw": "^2.12.10",
    "prettier": "^3.5.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.5"
  }
}
