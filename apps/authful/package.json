{
  "name": "@anticapture/authful",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "description": "Authful — per-tenant API token issuance, validation and usage tracking for Gateful",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "clean": "rm -rf node_modules *.tsbuildinfo dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "mint": "tsx scripts/mint-token.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anticapture/observability": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.2",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.7",
    "pg": "^8.17.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@types/node": "^20.16.5",
    "@types/pg": "^8.15.6",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.5"
  }
}
