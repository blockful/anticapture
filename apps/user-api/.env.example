# User API — user identity & session service

PORT=4003

# Dedicated Postgres for the User API (its own DB, not the DAO/general schema).
DATABASE_URL=postgresql://postgres:admin@localhost:5432/user_api

# Session signing key — must be >= 32 high-entropy chars.
BETTER_AUTH_SECRET=change-me-to-a-32+-char-random-secret
# Dashboard ORIGIN only — NOT the /api/user proxy path. better-auth mounts its
# routes at baseURL + basePath (/api/auth); the dashboard proxy already strips
# /api/user before forwarding, so the service receives /api/auth/* — including
# the path here would make better-auth expect /api/user/api/auth/* and 404.
# (Follow-up: magic-link/OAuth callback links need the proxy to preserve the
# /api/user prefix; not required for SIWE.)
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated SIWE hosts (main + whitelabel). One better-auth instance per
# host; a signed message must match the host it was produced on.
AUTH_SIWE_DOMAINS=localhost:3000
# Comma-separated CSRF origin allowlist (main + whitelabel origins).
TRUSTED_ORIGINS=http://localhost:3000

# RPC for EIP-1271 / smart-contract-wallet signature verification.
RPC_URL=https://eth.llamarpc.com

# Deferred (Google OAuth, magic link) — leave unset for SIWE-only.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# RESEND_API_KEY=

# Magic link (optional): set to enable email sign-in. Sender defaults to
# Resend's sandbox for dev.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=auth@anticapture.com

# Self-service API keys (optional): both must be set together. The User API
# brokers user-scoped keys into Authful over the private network.
# AUTHFUL_URL=http://localhost:4002
# AUTHFUL_PROVISIONING_API_KEY=
