NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
NEXT_PUBLIC_ALCHEMY_KEY=
NEXT_PUBLIC_SITE_URL=

# eRPC "dashboard" project (preferred over Alchemy when both are set)
# example: NEXT_PUBLIC_ERPC_URL=https://<erpc-host>/dashboard
NEXT_PUBLIC_ERPC_URL=
NEXT_PUBLIC_ERPC_SECRET=

# Gateful gateway base URL (server-only, read by the /api/gateful proxy)
ANTICAPTURE_API_URL=http://localhost:4001

# local whitelabel override for dashboard development
# example: FORCE_DAO=AAVE then visit http://localhost:3000/governance
FORCE_DAO=

# social media links
NEXT_PUBLIC_ANTICAPTURE_TELEGRAM_BOT=https://t.me/<your-telegram-username>
NEXT_PUBLIC_ANTICAPTURE_SLACK_BOT=https://<your-slack-server>/slack/

# resend API configuration for contact form
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
CONTACT_EMAIL=

# GitHub token for higher API rate limits (5000 req/hour vs 60 unauthenticated)
GITHUB_TOKEN=

# Blockful API token (server-only, injected by proxy)
BLOCKFUL_API_TOKEN=

# Etherscan v2 API key (server-only, used by /api/etherscan to fetch contract
# ABIs for custom proposal actions)
# https://etherscan.io/apis
ETHERSCAN_API_KEY=

# CoinGecko API key (server-only, optional — used by /api/coingecko for USD prices)
# https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=
