# Redis (rate-limit storage)
REDIS_URL=redis://localhost:6379

# DAO
DAO_NAME=ens

# Chain
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
CHAIN_ID=1

# DAO contracts
GOVERNOR_ADDRESS=0x...
TOKEN_ADDRESS=0x...

# Relayer wallet (v1: raw private key — migrate to KMS for production)
RELAYER_PRIVATE_KEY=0x...

# Voting power threshold
MIN_VOTING_POWER=1000000000000000000000

# Rate limiting
MAX_RELAY_PER_ADDRESS_PER_DAY=3

# Balance monitor
MIN_BALANCE_WEI=100000000000000000

# Auth (optional — omit to allow all requests)
BLOCKFUL_API_TOKEN=

# Server
PORT=4001
