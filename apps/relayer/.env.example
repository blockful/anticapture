# Chain
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
CHAIN_ID=1

# DAO contracts
GOVERNOR_ADDRESS=0x...
TOKEN_ADDRESS=0x...

# Relayer wallet (v1: raw private key — migrate to KMS for production)
RELAYER_PRIVATE_KEY=0x...

# Eligibility thresholds
MIN_VOTING_POWER=1000000000000000000000
DELEGATION_COOLDOWN_DAYS=7

# Rate limiting
MAX_RELAY_PER_ADDRESS_PER_DAY=50
MAX_RELAY_PER_ADDRESS_PER_HOUR=5

# Balance monitor
MIN_BALANCE_WEI=100000000000000000

# EIP-712 domain versions (most DAOs use "1", override if different)
GOVERNOR_EIP712_VERSION=1
TOKEN_EIP712_VERSION=1

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Server
PORT=4001
