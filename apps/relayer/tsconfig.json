{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "module": "ESNext",
    "lib": ["ES2022"],
    "target": "ES2022",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] },
    "outDir": "./dist",
    "moduleResolution": "bundler",
    "types": ["vitest/globals"]
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
