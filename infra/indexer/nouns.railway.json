{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/indexer/Dockerfile",
    "watchPatterns": ["apps/indexer/**", "infra/indexer/**"]
  },
  "deploy": {
    "healthcheckPath": "/ready",
    "restartPolicyType": "NEVER",
    "healthcheckTimeout": 172800
  },
  "environments": {
    "pr": {
      "deploy": {
        "startCommand": "echo 'NOOP'",
        "healthcheckPath": null,
        "preDeployCommand": null
      }
    }
  }
}
