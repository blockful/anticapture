{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/offchain-indexer/Dockerfile",
    "watchPatterns": ["apps/offchain-indexer/**", "infra/offchain-indexer/**"]
  },
  "deploy": {
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 3
  }
}
