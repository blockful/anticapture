{
  "title": "Anticapture",
  "uid": "anticapture",
  "editable": true,
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": ["anticapture"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Services Down",
      "description": "Count of anticapture services failing their Prometheus scrape. Anything above 0 is red.",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "count(up{job=~\"anticapture-.*\"} == 0) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "API Requests",
      "description": "Total request rate across all DAO APIs (5m average).",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=~\"anticapture-.*-api\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "API Error Rate",
      "description": "Share of DAO API requests returning 5xx (5m average). Green <1%, yellow <5%, red ≥5%.",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "(sum(rate(http_server_request_duration_seconds_count{job=~\"anticapture-.*-api\",http_response_status_code=~\"5..\"}[5m])) or vector(0)) / sum(rate(http_server_request_duration_seconds_count{job=~\"anticapture-.*-api\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "API p99 Latency",
      "description": "99th percentile latency across all DAO APIs (5m window). Green <500ms, yellow <2s, red ≥2s.",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=~\"anticapture-.*-api\"}[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Cache Hit Rate",
      "description": "Gateful cache hit ratio across all routes (5m average). Red <50%, yellow <80%, green ≥80%.",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "sum(rate(cache_requests_total{job=\"anticapture-gateful\",result=\"hit\"}[5m])) / sum(rate(cache_requests_total{job=\"anticapture-gateful\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "eRPC Critical Errors (5m)",
      "description": "Critical network-level + upstream-level eRPC errors in the last 5 minutes. Anything above 0 is red.",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "(sum(increase(erpc_network_failed_request_total{job=\"anticapture-erpc\",severity=\"critical\"}[5m])) or vector(0)) + (sum(increase(erpc_upstream_request_errors_total{job=\"anticapture-erpc\",severity=\"critical\",composite=\"none\"}[5m])) or vector(0))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Service Health",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 11,
      "title": "Scrape Status — all services",
      "description": "One cell per scraped service (APIs, indexers, gateful, authful, erpc). Green UP / red DOWN.",
      "type": "stat",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": { "1": { "text": "UP", "color": "green" } }
            },
            {
              "type": "value",
              "options": { "0": { "text": "DOWN", "color": "red" } }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "label_replace(up{job=~\"anticapture-.*\"}, \"service\", \"$1\", \"job\", \"anticapture-(.*)\")",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "title": "API Traffic",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 11, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 21,
      "title": "Request Rate by DAO",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "label_replace(sum by (job) (rate(http_server_request_duration_seconds_count{job=~\"anticapture-.*-api\"}[5m])), \"dao\", \"$1\", \"job\", \"anticapture-(.*)-api\")",
          "legendFormat": "{{dao}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "title": "Error Rate (5xx) by DAO",
      "description": "Empty panel = no 5xx errors in the selected window.",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "label_replace(sum by (job) (rate(http_server_request_duration_seconds_count{job=~\"anticapture-.*-api\",http_response_status_code=~\"5..\"}[5m])), \"dao\", \"$1\", \"job\", \"anticapture-(.*)-api\") > 0",
          "legendFormat": "{{dao}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "title": "API Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=~\"anticapture-.*-api\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=~\"anticapture-.*-api\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{job=~\"anticapture-.*-api\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "C"
        }
      ]
    },
    {
      "id": 24,
      "title": "Active Routes — req/s / p99 / error ratio",
      "description": "Only routes with traffic in the last 5 minutes. One row per (DAO, route). Error ratio cell is threshold-colored: green <1%, yellow <5%, red ≥5%.",
      "type": "table",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "req/s" },
            "properties": [
              { "id": "unit", "value": "reqps" },
              { "id": "decimals", "value": 3 },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p99 latency" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 3 },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "error ratio" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.width", "value": 120 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.01 },
                    { "color": "red", "value": 0.05 }
                  ]
                }
              },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "error ratio", "desc": true }],
        "footer": { "show": false },
        "frameIndex": 0,
        "showHeader": true
      },
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "job": true
            },
            "renameByName": {
              "Value #A": "req/s",
              "Value #B": "p99 latency",
              "Value #C": "error ratio",
              "dao": "DAO",
              "http_route": "route"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "label_replace(sum(rate(http_server_request_duration_seconds_count{job=~\"anticapture-.*-api\"}[5m])) by (job, http_route) > 0, \"dao\", \"$1\", \"job\", \"anticapture-(.*)-api\")",
          "legendFormat": "{{dao}}|{{http_route}}",
          "instant": true,
          "refId": "A",
          "format": "table"
        },
        {
          "expr": "label_replace(histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=~\"anticapture-.*-api\"}[5m])) by (le, job, http_route)) and sum(rate(http_server_request_duration_seconds_count{job=~\"anticapture-.*-api\"}[5m])) by (job, http_route) > 0, \"dao\", \"$1\", \"job\", \"anticapture-(.*)-api\")",
          "legendFormat": "{{dao}}|{{http_route}}",
          "instant": true,
          "refId": "B",
          "format": "table"
        },
        {
          "expr": "label_replace((sum(rate(http_server_request_duration_seconds_count{job=~\"anticapture-.*-api\",http_response_status_code=~\"5..\"}[5m])) by (job, http_route) or sum(rate(http_server_request_duration_seconds_count{job=~\"anticapture-.*-api\"}[5m])) by (job, http_route) * 0) / (sum(rate(http_server_request_duration_seconds_count{job=~\"anticapture-.*-api\"}[5m])) by (job, http_route) > 0), \"dao\", \"$1\", \"job\", \"anticapture-(.*)-api\")",
          "legendFormat": "{{dao}}|{{http_route}}",
          "instant": true,
          "refId": "C",
          "format": "table"
        }
      ]
    },
    {
      "id": 30,
      "title": "Gateway (Gateful)",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 31,
      "title": "Cache Hit Rate by Route",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 30, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum(rate(cache_requests_total{job=\"anticapture-gateful\",result=\"hit\"}[5m])) by (route) / sum(rate(cache_requests_total{job=\"anticapture-gateful\"}[5m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 32,
      "title": "Cache Hits vs Misses",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 30, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "hit" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "green" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "miss" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "red" }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum(rate(cache_requests_total{job=\"anticapture-gateful\"}[5m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 33,
      "title": "Requests by Client Source",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 30, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"anticapture-gateful\"}[5m])) by (client_source)",
          "legendFormat": "{{client_source}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 34,
      "title": "Requests by Tenant & Route",
      "description": "Authenticated request totals over the selected time range. Who is using what.",
      "type": "table",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "sortBy": [{ "displayName": "requests", "desc": true }],
        "footer": { "show": false },
        "showHeader": true
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "Value #A": "requests",
              "route": "route",
              "tenant": "tenant"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "sum(increase(tenant_requests_total{job=\"anticapture-gateful\"}[$__range])) by (route, tenant)",
          "legendFormat": "{{tenant}}|{{route}}",
          "instant": true,
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "id": 40,
      "title": "eRPC (Upstream RPC)",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 44, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 41,
      "title": "Incoming RPS",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 45, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum(rate(erpc_network_request_received_total{job=\"anticapture-erpc\"}[$__rate_interval])) by (network, category)",
          "legendFormat": "{{network}} / {{category}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 42,
      "title": "Critical Errors",
      "description": "Network-level and upstream-level critical errors. Empty panel = no critical errors in the selected window.",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 45, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum(increase(erpc_network_failed_request_total{job=\"anticapture-erpc\", severity=\"critical\"}[$__rate_interval])) by (network, error) > 0",
          "legendFormat": "net {{network}} / {{error}}",
          "refId": "A"
        },
        {
          "expr": "sum(increase(erpc_upstream_request_errors_total{job=\"anticapture-erpc\", severity=\"critical\", composite=\"none\"}[$__rate_interval])) by (upstream, error) > 0",
          "legendFormat": "{{upstream}} / {{error}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 43,
      "title": "Upstream p99 Response Time",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 45, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(erpc_upstream_request_duration_seconds_bucket{job=\"anticapture-erpc\", composite=\"none\"}[$__rate_interval])) by (le, upstream))",
          "legendFormat": "{{upstream}}",
          "refId": "A"
        }
      ]
    },
