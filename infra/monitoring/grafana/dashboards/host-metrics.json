{
  "title": "Host Metrics",
  "uid": "anticapture-host",
  "editable": true,
  "schemaVersion": 38,
  "version": 2,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Process CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(process_cpu_utilization) by (exported_job, process_cpu_state)",
          "legendFormat": "{{exported_job}} - {{process_cpu_state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Process Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(process_memory_usage) by (exported_job, process_memory_type)",
          "legendFormat": "{{exported_job}} - {{process_memory_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "System CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(system_cpu_utilization) by (system_cpu_state)",
          "legendFormat": "{{system_cpu_state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "System Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(system_memory_usage) by (system_memory_state)",
          "legendFormat": "{{system_memory_state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(system_network_io_total[1m])) by (network_io_direction)",
          "legendFormat": "{{network_io_direction}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Network Errors & Drops",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(system_network_errors_total[1m])) by (network_io_direction)",
          "legendFormat": "errors {{network_io_direction}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(system_network_dropped_total[1m])) by (network_io_direction)",
          "legendFormat": "drops {{network_io_direction}}",
          "refId": "B"
        }
      ]
    }
  ]
}
