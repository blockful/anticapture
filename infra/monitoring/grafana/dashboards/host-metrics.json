{
  "title": "Host Metrics",
  "uid": "anticapture-host",
  "editable": true,
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(process_cpu_time_seconds_total[1m]) * 100",
          "legendFormat": "{{state}} - {{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes",
          "legendFormat": "heap used - {{job}}",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_total_bytes",
          "legendFormat": "heap total - {{job}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Memory RSS",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS - {{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Event Loop Lag (p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_p99_seconds",
          "legendFormat": "p99 lag - {{job}}",
          "refId": "A"
        },
        {
          "expr": "nodejs_eventloop_lag_mean_seconds",
          "legendFormat": "mean lag - {{job}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Handles & Requests",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "nodejs_active_handles_total",
          "legendFormat": "active handles - {{job}}",
          "refId": "A"
        },
        {
          "expr": "nodejs_active_requests_total",
          "legendFormat": "active requests - {{job}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "GC Duration (rate)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(nodejs_gc_duration_seconds_sum[1m])",
          "legendFormat": "GC time/s - {{job}} {{kind}}",
          "refId": "A"
        }
      ]
    }
  ]
}
