{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/relayer/Dockerfile",
    "watchPatterns": ["apps/relayer/**", "infra/relayer/**"]
  },
  "deploy": {
    "healthcheckPath": "/health",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 3
  }
}
