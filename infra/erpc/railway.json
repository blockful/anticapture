{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/erpc/Dockerfile",
    "watchPatterns": ["/infra/erpc/**"]
  },
  "deploy": {
    "restartPolicyMaxRetries": 3,
    "restartPolicyType": "ALWAYS",
    "healthcheckPath": "/healthcheck"
  }
}
