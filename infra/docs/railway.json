{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/docs/Dockerfile",
    "watchPatterns": [
      "packages/anticapture-client/docs/**",
      "infra/docs/**",
      "apps/api/**",
      "apps/docs/**",
      "apps/gateful/**"
    ]
  },
  "environments": {
    "pr": {
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "infra/noop/Dockerfile"
      },
      "deploy": {
        "startCommand": "echo 'NOOP'",
        "healthcheckPath": null,
        "preDeployCommand": null
      }
    }
  }
}
