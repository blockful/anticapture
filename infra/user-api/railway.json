{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/user-api/Dockerfile",
    "watchPatterns": ["apps/user-api/**", "infra/user-api/**"]
  },
  "deploy": {
    "healthcheckPath": "/health",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 3
  }
}
