{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/api-gateway/Dockerfile",
    "watchPatterns": [
      "apps/api-gateway/**",
      "infra/api-gateway/**",
      "apps/api/**/*.ts",
      "apps/address-enrichment/**/*.ts"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 3
  }
}
