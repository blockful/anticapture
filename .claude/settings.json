{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "LS",
      "Edit",
      "MultiEdit",
      "Write",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(pnpm run *)",
      "Bash(pnpm test *)",
      "Bash(pnpm install *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm typecheck *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "PKG=$(echo \"$CLAUDE_FILE_PATH\" | grep -oE '(apps|packages)/[^/]+' | head -1) && [ -n \"$PKG\" ] && pnpm --filter \"./$PKG\" lint:fix 2>&1 || true"
          },
          {
            "type": "command",
            "command": "PKG=$(echo \"$CLAUDE_FILE_PATH\" | grep -oE '(apps|packages)/[^/]+' | head -1) && [ -n \"$PKG\" ] && pnpm --filter \"./$PKG\" typecheck 2>&1 || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "andrej-karpathy-skills@karpathy-skills": true
  }
}
